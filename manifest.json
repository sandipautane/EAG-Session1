{
  "manifest_version": 3,
  "name": "TimeScape - Usage Tracker",
  "version": "1.0.0",
  "description": "Seamlessly track, manage, and visualize your website usage time.",
  "permissions": [
    "tabs",
    "storage",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "View TimeStats"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
